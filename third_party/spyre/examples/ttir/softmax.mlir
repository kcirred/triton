// Row-wise softmax TTIR using tensor descriptors (f16 input/output).
//
// For each row i in [0, M):
//   row = input[i, 0:N]
//   row_max = max(row)
//   row_shifted = row - row_max
//   numerator = exp(row_shifted)
//   denominator = sum(numerator)
//   output[i, 0:N] = numerator / denominator
//
// Generated by gen_softmax.py, then cleaned up (locations stripped,
// SSA names simplified).

module {
  tt.func public @softmax_kernel_desc(
      %output_ptr: !tt.ptr<f16>,
      %input_ptr: !tt.ptr<f16>,
      %M: i32,
      %N: i32
  ) attributes {noinline = false} {
    %row_idx = tt.get_program_id x : i32

    // Descriptor construction
    %stride_row = arith.extsi %N : i32 to i64
    %stride_col = arith.constant 1 : i64
    %in_desc = tt.make_tensor_descriptor %input_ptr, [%M, %N], [%stride_row, %stride_col]
        : <f16>, <1x1024xf16>
    %out_desc = tt.make_tensor_descriptor %output_ptr, [%M, %N], [%stride_row, %stride_col]
        : <f16>, <1x1024xf16>

    // Load one row
    %c0 = arith.constant 0 : i32
    %row = tt.descriptor_load %in_desc[%row_idx, %c0]
        : !tt.tensordesc<1x1024xf16> -> tensor<1x1024xf16>

    // row_max = max(row)
    %row_max = tt.call @triton.language.standard.max__fp16S1_1024S_c1_cFalse_cTrue_cFalse(%row)
        : (tensor<1x1024xf16>) -> tensor<1xf32>

    // row_shifted = row - row_max (broadcast max across columns)
    %row_f32 = arith.extf %row : tensor<1x1024xf16> to tensor<1x1024xf32>
    %row_max_2d = tt.expand_dims %row_max {axis = 0 : i32}
        : tensor<1xf32> -> tensor<1x1xf32>
    %row_max_bcast = tt.broadcast %row_max_2d
        : tensor<1x1xf32> -> tensor<1x1024xf32>
    %row_shifted = arith.subf %row_f32, %row_max_bcast : tensor<1x1024xf32>

    // numerator = exp(row_shifted)
    %numerator = math.exp %row_shifted : tensor<1x1024xf32>

    // denominator = sum(numerator)
    %denominator = tt.call @triton.language.standard.sum__fp32S1_1024S_c1_cFalse_cNone(%numerator)
        : (tensor<1x1024xf32>) -> tensor<1xf32>

    // softmax_out = numerator / denominator (broadcast)
    %denom_2d = tt.expand_dims %denominator {axis = 0 : i32}
        : tensor<1xf32> -> tensor<1x1xf32>
    %denom_bcast = tt.broadcast %denom_2d
        : tensor<1x1xf32> -> tensor<1x1024xf32>
    %softmax_f32 = arith.divf %numerator, %denom_bcast : tensor<1x1024xf32>

    // Truncate back to f16 and store
    %softmax_out = arith.truncf %softmax_f32
        : tensor<1x1024xf32> to tensor<1x1024xf16>
    tt.descriptor_store %out_desc[%row_idx, %c0], %softmax_out
        : !tt.tensordesc<1x1024xf16>, tensor<1x1024xf16>
    tt.return
  }

  // --- Helper functions (inlined from triton.language.standard) ---

  tt.func private @triton.language.standard.max__fp16S1_1024S_c1_cFalse_cTrue_cFalse(
      %input: tensor<1x1024xf16>
  ) -> tensor<1xf32> attributes {noinline = false} {
    %input_f32 = arith.extf %input : tensor<1x1024xf16> to tensor<1x1024xf32>
    %0 = "tt.reduce"(%input_f32) <{axis = 1 : i32}> ({
    ^bb0(%a: f32, %b: f32):
      %1 = tt.call @triton.language.standard._elementwise_max__fp32_fp32(%a, %b) : (f32, f32) -> f32
      tt.reduce.return %1 : f32
    }) : (tensor<1x1024xf32>) -> tensor<1xf32>
    tt.return %0 : tensor<1xf32>
  ^bb1:
    %poison = ub.poison : tensor<1xf32>
    tt.return %poison : tensor<1xf32>
  }

  tt.func private @triton.language.standard._elementwise_max__fp32_fp32(
      %a: f32, %b: f32
  ) -> f32 attributes {noinline = false} {
    %0 = arith.maxnumf %a, %b : f32
    tt.return %0 : f32
  ^bb1:
    %poison = ub.poison : f32
    tt.return %poison : f32
  }

  tt.func private @triton.language.standard.sum__fp32S1_1024S_c1_cFalse_cNone(
      %input: tensor<1x1024xf32>
  ) -> tensor<1xf32> attributes {noinline = false} {
    %0 = "tt.reduce"(%input) <{axis = 1 : i32}> ({
    ^bb0(%a: f32, %b: f32):
      %1 = tt.call @triton.language.standard._sum_combine__fp32_fp32(%a, %b) : (f32, f32) -> f32
      tt.reduce.return %1 : f32
    }) : (tensor<1x1024xf32>) -> tensor<1xf32>
    tt.return %0 : tensor<1xf32>
  ^bb1:
    %poison = ub.poison : tensor<1xf32>
    tt.return %poison : tensor<1xf32>
  }

  tt.func private @triton.language.standard._sum_combine__fp32_fp32(
      %a: f32, %b: f32
  ) -> f32 attributes {noinline = false} {
    %0 = arith.addf %a, %b : f32
    tt.return %0 : f32
  ^bb1:
    %poison = ub.poison : f32
    tt.return %poison : f32
  }
}
