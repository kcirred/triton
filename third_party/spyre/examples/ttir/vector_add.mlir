// Vector-add TTIR using tensor descriptors.
//
// Triton kernel: C[i] = A[i] + B[i] for i in [0, N)
// Each program instance handles one BLOCK_SIZE=1024 chunk.
// N = 98304 (96 blocks × 1024) is a compile-time constant.
// Generated by gen_ttir.py, then cleaned up (locations stripped,
// SSA names simplified).

module {
  tt.func public @add_kernel_desc(
      %x_ptr: !tt.ptr<f16>,
      %y_ptr: !tt.ptr<f16>,
      %output_ptr: !tt.ptr<f16>
  ) attributes {noinline = false} {
    %pid = tt.get_program_id x : i32

    %block_size = arith.constant 1024 : i32
    %offset = arith.muli %pid, %block_size : i32

    %N = arith.constant 98304 : i32
    %stride = arith.constant 1 : i64
    %x_desc = tt.make_tensor_descriptor %x_ptr, [%N], [%stride]
        : <f16>, <1024xf16>
    %y_desc = tt.make_tensor_descriptor %y_ptr, [%N], [%stride]
        : <f16>, <1024xf16>
    %out_desc = tt.make_tensor_descriptor %output_ptr, [%N], [%stride]
        : <f16>, <1024xf16>

    %x = tt.descriptor_load %x_desc[%offset]
        : !tt.tensordesc<1024xf16> -> tensor<1024xf16>
    %y = tt.descriptor_load %y_desc[%offset]
        : !tt.tensordesc<1024xf16> -> tensor<1024xf16>

    %output = arith.addf %x, %y : tensor<1024xf16>

    tt.descriptor_store %out_desc[%offset], %output
        : !tt.tensordesc<1024xf16>, tensor<1024xf16>
    tt.return
  }
}
